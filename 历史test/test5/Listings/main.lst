  20          // 核心门控函数：控制 138译码器 打通指定的 573锁存器 通道
  21          void Select_HC573(unsigned char channel)
  22          {
  23   1        // P2 端口的高三位（P2.7, P2.6, P2.5）控制 138 译码器
  24   1        P2 = (P2 & 0x1F) | 0x00; // 先把高三位清零，防止干扰
  25   1        
  26   1        switch(channel)
  27   1        {
  28   2          case 4: P2 = (P2 & 0x1F) | 0x80; break; // 选择 Y4C，打通 LED 控制通道
  29   2          case 5: P2 = (P2 & 0x1F) | 0xA0; break; // 选择 Y5C，打通 蜂鸣器/继电器 控制通道
  30   2        }
  31   1      }
  32          
  33          // 主函数
  34          void main()
  35          {
  36   1        // 1. 定义一个变量，装载初始的 LED 状态 (0xFE 也就是二进制 1111 1110，最低位灯亮)
  37   1        unsigned char led_data = 0xFE; 
  38   1      
  39   1        // 2. 蓝桥杯上电必备操作：关闭蜂鸣器，防止发出刺耳噪音
  40   1        Select_HC573(5); // 打通蜂鸣器通道
  41   1        P0 = 0x00;       // 写入低电平关闭蜂鸣器
  42   1        Select_HC573(0); // 锁死通道
  43   1      
  44   1        // 3. 主循环
  45   1        while (1)
  46   1        {
  47   2          // 第 1 步：输出电平点亮 LED
  48   2          Select_HC573(4);  // 打通 LED 控制通道
  49   2          P0 = led_data;    // 把当前的 led_data 状态丢给 P0 口
  50   2          Select_HC573(0);  // 锁死通道，LED 状态保持不变
  51   2      
  52   2          // 第 2 步：延时停留，让肉眼能看清灯亮着
  53   2          Delay(500);       // 停留 500 毫秒 (0.5秒)
  54   2      
