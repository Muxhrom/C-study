  14          // 定时器初始化 (ISP生成粘贴过来)
  15          void timer0_init(void) 
  16          {
  17   1          AUXR |= 0x80; 
  18   1          TMOD &= 0xF0; 
  19   1          TL0 = 0x20;   
  20   1          TH0 = 0xD1;   
