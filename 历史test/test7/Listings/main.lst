  35          
  36          // 按键业务处理
  37          void key_proc()
  38          {
  39   1          if(key_tick < 10) return; // 10ms 消抖
  40   1          key_tick = 0;             
  41   1      
  42   1          // 状态机三步曲
  43   1          key_val = key_read(); 
  44   1          key_down = key_val & (key_val ^ key_old); // 提取按下瞬间的动作
  45   1          key_up = ~key_val & (key_val ^ key_old);  // 提取松开瞬间的动作
  46   1          key_old = key_val;
  47   1      
  48   1          // 根据“真实键码”执行动作
  49   1          switch(key_down)
  50   1          {
  51   2              case 4:  // S7 按下 (键码是4)
  52   2                  seg_buf[0] = 1; 
  53   2                  break;
  54   2                  
